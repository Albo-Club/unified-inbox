# ============================================================================
# Albo Start MVP — env vars
# Copy this file to .env.local and fill in the values.
# ============================================================================

# --- Convex ----------------------------------------------------------------
# Set automatically by `pnpm exec convex dev` (do not edit manually)
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=

# --- Better Auth -----------------------------------------------------------
# 32-byte random hex (generate with: node -e "console.log(crypto.randomBytes(32).toString('hex'))")
BETTER_AUTH_SECRET=
# The URL where the app is hosted (used to issue JWT tokens)
BETTER_AUTH_URL=http://localhost:3000

# --- App metadata (optional) -----------------------------------------------
APP_NAME="Albo MVP"

# --- Email (optional, only if requireEmailVerification: true) --------------
# Get a free key at https://resend.com (no card required for test domain)
RESEND_API_KEY=
# In test mode, use onboarding@resend.dev (works with any Resend key).
# In production with a verified domain, use noreply@yourdomain.com
RESEND_EMAIL_SENDER=onboarding@resend.dev

# --- AI provider (at least ONE of these must be set for the chat sidebar) --
# Recommended: Anthropic (best for tool-calling)
ANTHROPIC_API_KEY=
# Alternative: OpenRouter (multi-provider routing)
OPENROUTER_API_KEY=
# Alternative: OpenAI
OPENAI_API_KEY=
# Alternative: Google
GOOGLE_GENERATIVE_AI_API_KEY=

# --- Unified email --------------------------------------------------------
# Google OAuth credentials (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# AES-GCM key (32 bytes hex) for encrypting OAuth tokens + IMAP passwords in Convex
# Generate: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
