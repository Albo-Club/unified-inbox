{
  "name": "albo-start-mvp",
  "version": "0.1.0",
  "description": "AI-first MVP scaffold by Studio Albo. TanStack Start + Convex + Better Auth + shadcn/ui + AI chat sidebar with tool-calling.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,convex -c blue,green \"vite dev\" \"pnpm exec convex dev\"",
    "dev:vite": "vite dev",
    "dev:convex": "pnpm exec convex dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.76",
    "@ai-sdk/google": "^3.0.71",
    "@ai-sdk/openai": "^3.0.63",
    "@ai-sdk/react": "^3.0.179",
    "@convex-dev/agent": "^0.6.1",
    "@convex-dev/better-auth": "^0.12.2",
    "@convex-dev/resend": "^0.2.3",
    "@hookform/resolvers": "^3.9.1",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.6",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-start": "^1.167.65",
    "ai": "^6.0.177",
    "better-auth": "^1.6.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.38.0",
    "lucide-react": "^0.468.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.54.2",
    "react-markdown": "^9.0.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/router-plugin": "^1.167.35",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "8.0.9"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
